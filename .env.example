# ─── App ───────────────────────────────
NEXT_PUBLIC_APP_URL=https://tradeai-signals.vercel.app
INTERNAL_APP_URL=https://tradeai-signals.vercel.app

# ─── Motor IA / Python ─────────────────
USE_PYTHON_BOT=true
PYTHON_BOT_URL=http://localhost:8000
PYTHON_BOT_SECRET=secret_xxxx
MARKET_DATA_CACHE_TTL_MS=45000

# ─── Supabase ──────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Stripe ────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_BASIC=
STRIPE_PRICE_PREMIUM=

# ─── Email (Resend) ────────────────────
RESEND_API_KEY=re_xxxx
RESEND_FROM_EMAIL="TradeAI <onboarding@resend.dev>"

# ─── Telegram Bot ──────────────────────
TELEGRAM_BOT_TOKEN=xxxx:xxxxx
# Opcional: define o mesmo secret ao configurar o webhook no Telegram
TELEGRAM_WEBHOOK_SECRET=

# ─── Analytics ────────────────────────
NEXT_PUBLIC_GA4_ID=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
